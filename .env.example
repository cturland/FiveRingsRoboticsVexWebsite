# RobotEvents API settings (set in local .env or deployment environment variables)
ROBOTEVENTS_API_TOKEN=your_api_token_here
ROBOTEVENTS_DEBUG=false

# Supabase auth settings for student uploads
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_GALLERY_BUCKET=gallery-uploads
NEXT_PUBLIC_SITE_URL=http://localhost:3000
